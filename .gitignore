# ---------------------------------------------
# Go build outputs
# ---------------------------------------------
/bin/
/dist/
*.exe
*.dll
*.so
*.dylib
*.test

# ---------------------------------------------
# Go test and coverage outputs
# ---------------------------------------------
coverage.out
*.cover

# ---------------------------------------------
# Local Go cache
# ---------------------------------------------
.gocache/
.gomodcache/

# ---------------------------------------------
# Runtime storage
# ---------------------------------------------
storage/tmp/*
storage/csv/*
storage/logs/*
!storage/tmp/.gitkeep
!storage/csv/.gitkeep
!storage/logs/.gitkeep

# ---------------------------------------------
# Local environment files
# ---------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------
# OS and editor files
# ---------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
